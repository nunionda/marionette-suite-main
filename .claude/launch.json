      "cwd": "apps/contents-studio/apps/api"
    },
    {
      "name": "studio",
      "runtimeExecutable": "bunx",
      "runtimeArgs": ["next", "dev", "-p", "3001"],
      "port": 3001,
      "cwd": "apps/studio"
    },
    {
      "name": "contents-studio-scenario-web",
      "runtimeExecutable": "bunx",
      "runtimeArgs": ["next", "dev", "--port", "4000"],
      "port": 4000,
      "cwd": "apps/contents-studio/apps/scenario-web"
    },
    {
      "name": "post-studio",
      "runtimeExecutable": "bunx",
      "runtimeArgs": ["next", "dev", "--turbopack", "--port", "4002"],
      "port": 4002,
      "cwd": "apps/post-studio"
    },
    {
      "name": "content-library",
      "runtimeExecutable": "bunx",
