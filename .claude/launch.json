{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "script-writer-frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "5174", "--host", "0.0.0.0"],
      "port": 5174,
      "cwd": "apps/script-writer"
    },
    {
      "name": "script-writer-backend",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "src/index.ts"],
      "port": 3006,
      "cwd": "apps/script-writer/server"
    },
    {
      "name": "shorts-factory-frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "5178", "--host", "0.0.0.0"],
      "port": 5178,
      "cwd": "apps/shorts-factory"
    },
    {
      "name": "analysis-web",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "dev"],
      "port": 4007,
      "cwd": "apps/analysis-system/apps/web"
    },
    {
      "name": "analysis-api",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["run", "--watch", "src/index.ts"],
      "port": 4006,
      "cwd": "apps/analysis-system/apps/api"
    }
  ]
}
