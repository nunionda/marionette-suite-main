{
  "name": "marionette-studio",
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3"
  },
  "private": true,
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "test:file": "bun test",
    "lint": "eslint .",
    "lint:file": "eslint",
    "lint:claude": "bun run lint",
    "dev:api": "bun run --filter @marionette/api dev",
    "dev:web": "bun run --filter @marionette/web dev",
    "db:generate": "bun run --filter @marionette/db generate",
    "db:push": "bun run --filter @marionette/db push",
    "db:seed": "bun run --filter @marionette/db seed",
    "dev:scenario-api": "bun run --filter @marionette/scenario-api dev",
    "dev:scenario-web": "bun run --filter @marionette/scenario-web dev",
    "scenario:db:generate": "bun run --filter @marionette/scenario-db db:generate",
    "scenario:db:push": "bun run --filter @marionette/scenario-db db:push"
  },
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "dependencies": {
    "@prisma/client": "6.19.2"
  }
}
