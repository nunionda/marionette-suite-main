# === 마리오네트 프로덕션 파이프라인 환경 변수 ===
# .env.example → .env 복사 후 실제 값으로 교체하세요

# ── AI API 키 ──────────────────────────────────────────────────────────────────
# Gemini API: 무료 티어 지원 (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude: 유료 API, 남은 크레딧 허용 범위에서만 사용
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Groq: 무료 티어 지원 (https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_key_here

# ── 데이터베이스 ────────────────────────────────────────────────────────────────
# SQLite (기본 — 별도 설치 불필요)
DATABASE_URL=sqlite:///./marionette.db

# ── 웹 서버 설정 ────────────────────────────────────────────────────────────────
# 파이프라인 API 서버 포트 (기본: 3005)
PORT=3005

# CORS 허용 Origin (Next.js 스튜디오)
WEB_ORIGIN=http://localhost:3001

# ── 선택 사항 ────────────────────────────────────────────────────────────────
# TMDB 영화 정보 API (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_key

# KOFIC 한국영화진흥위원회 API
KOFIC_API_KEY=your_kofic_key

# Pinecone 벡터 DB
PINECONE_API_KEY=your_pinecone_key

# ElevenLabs TTS (https://elevenlabs.io) — 향후 sound_designer TTS 연동용
ELEVENLABS_API_KEY=your_elevenlabs_key

# Suno AI 음악 생성 (https://suno.com) — 향후 BGM 자동 생성용
SUNO_API_KEY=your_suno_key
