generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  projects     Project[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Project {
  id                String        @id @default(cuid())
  title             String
  category          String        @default("") // Movie, Series, Commercial
  status            ProjectStatus @default(DRAFT)
  progress          Float         @default(0)
  
  // Leveled Architecture: Level 2 Development Context
  development       DevelopmentContext?
  
  // Asset & Analysis Context
  analysisData      Json?
  storyboardImages  Json?
  
  // Production Execution Data
  directionPlan     Json?
  directionPlanPath String?
  
  // Relations
  pipelineRuns      PipelineRun[]
  assets            Asset[]
  analysisReports   AnalysisReport[]
  screenplay        Screenplay?
  snapshots         ProjectSnapshot[]
  batchRuns         BatchRun[]
  outlines          ProjectOutline[]
  userId            String?
  user              User?         @relation(fields: [userId], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model DevelopmentContext {
  id                String   @id @default(cuid())
  projectId         String   @unique
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  genre             String   @default("")
  logline           String   @default("")
  idea              String   @default("")
  
  // Creative DNA
  protagonist       String   @default("") @db.Text
  antagonist        String   @default("") @db.Text
  worldview         String   @default("") @db.Text
  characters        Json?
  
  // Legacy Scripting Stages (Support for older assets)
  concept           String?  @db.Text
  architecture      String?  @db.Text
  treatment         String?  @db.Text
  scenario          String?  @db.Text
  review            String?  @db.Text
  script            String?  @db.Text

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Screenplay {
  id           String   @id @default(cuid())
  projectId    String   @unique
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentStep  Int      @default(1)
  outline      String?  @db.Text
  characters   Json?
  sceneLogs    String?  @db.Text
  draft        String?  @db.Text
  draftVersion Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PipelineRun {
  id           String          @id @default(cuid())
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase        ProductionPhase
  steps        Json
  currentStep  String?
  status       RunStatus       @default(QUEUED)
  progress     Float           @default(0)
  stepResults  Json            @default("{}")
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
}

model Asset {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        AssetType
  phase       ProductionPhase
  agentName   String
  sceneNumber Int?
  filePath    String
  fileName    String
  mimeType    String
  fileSize    Int?
  metadata    Json?
  createdAt   DateTime        @default(now())
}

model ProjectSnapshot {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String   // DIRECTION_PLAN, SCREENPLAY_OUTLINE, SCREENPLAY_DRAFT, SCREENPLAY_CHARACTERS
  version   Int
  label     String?
  data      Json
  createdAt DateTime @default(now())

  @@index([projectId, type])
  @@unique([projectId, type, version])
}

model AgentConfig {
  id        String          @id @default(cuid())
  agentName String          @unique
  phase     ProductionPhase
  provider  String
  model     String
  enabled   Boolean         @default(true)
  config    Json?
  updatedAt DateTime        @updatedAt
}

enum ProjectStatus {
  DRAFT
  PRE_PRODUCTION
  MAIN_PRODUCTION
  POST_PRODUCTION
  COMPLETED
  ARCHIVED
}

enum ProductionPhase {
  PRE
  MAIN
  POST
}

enum RunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AssetType {
  IMAGE
  VIDEO
  AUDIO
  MODEL_3D
  DOCUMENT
}

enum TaskStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  REGENERATING
}

model BatchRun {
  id              String      @id @default(cuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status          RunStatus   @default(QUEUED)
  totalScenes     Int
  completedScenes Int         @default(0)
  progress        Float       @default(0)
  errorMessage    String?
  sceneTasks      SceneTask[]
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model SceneTask {
  id           String     @id @default(cuid())
  batchRunId   String
  batchRun     BatchRun   @relation(fields: [batchRunId], references: [id], onDelete: Cascade)
  sceneNumber  Int
  status       TaskStatus @default(QUEUED)
  currentStep  String?
  stepResults  Json       @default("{}")
  attempt      Int        @default(1)
  errorMessage String?
  cutTasks     CutTask[]
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([batchRunId, sceneNumber])
}

model CutTask {
  id           String     @id @default(cuid())
  sceneTaskId  String
  sceneTask    SceneTask  @relation(fields: [sceneTaskId], references: [id], onDelete: Cascade)
  cutNumber    Int
  status       TaskStatus @default(QUEUED)
  steps        Json
  currentStep  String?
  stepResults  Json       @default("{}")
  attempt      Int        @default(1)
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([sceneTaskId, cutNumber])
}

model AnalysisReport {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  market    String   @default("hollywood")
  totalElements   Int
  protagonist     String?
  predictedRoi    String  
  predictedRating String  

  sceneCount              Int
  characterCount          Int
  dialogueLineCount       Int
  actionLineCount         Int
  dialogueToActionRatio   Float
  averageWordsPerDialogue Float

  characterNetwork Json
  beatSheet        Json
  emotionGraph     Json
  predictions      Json
  coverage         Json?
  production       Json?
  narrativeArc     Json?
  tropes           Json?

  @@index([predictedRoi])
  @@index([predictedRating])
  @@index([createdAt])
  @@map("analysis_reports")
}

model LoglineIdea {
  id        String   @id @default(cuid())
  content   String   @db.Text
  genre     String?
  category  String?
  source    String?  // e.g., "AI_GENERATED", "HUMAN_INPUT"
  createdAt DateTime @default(now())
}

model ProjectOutline {
  id           String     @id @default(cuid())
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  act          Int        // 1, 2, 3
  sceneNumber  Int
  title        String?
  description  String?    @db.Text
  status       String     @default("Planned") 
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([projectId])
}
