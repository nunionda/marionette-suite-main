# ─── YouTube API (OAuth2) ───
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3008/api/auth/youtube/callback
YOUTUBE_REFRESH_TOKEN=

# ─── Groq (Whisper STT - free tier) ───
GROQ_API_KEY=

# ─── Gemini (Translation + Metadata - free tier) ───
GEMINI_API_KEY=

# ─── Server ───
PORT=3008
FRONTEND_PORT=5178

# ─── Worker ───
WORKER_POLL_INTERVAL_MS=5000
MAX_CONCURRENT_RENDERS=2
