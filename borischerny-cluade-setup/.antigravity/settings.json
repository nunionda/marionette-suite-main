{
  "allowedCommands": [
    "bun run typecheck",
    "bun run test",
    "bun run test:file",
    "bun run lint",
    "bun run lint:file",
    "bun run lint:antigravity",
    "git status",
    "git diff",
    "git log",
    "git branch",
    "git add",
    "gh pr"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run lint:file -- \"$CLAUDE_FILE_PATH\" --fix 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
