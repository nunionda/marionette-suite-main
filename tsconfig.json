{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "@marionette/shared": ["./packages/shared/src"],
      "@marionette/shared/*": ["./packages/shared/src/*"],
      "@marionette/agents": ["./packages/agents/src"],
      "@marionette/agents/*": ["./packages/agents/src/*"],
      "@marionette/ai-gateway": ["./packages/ai-gateway/src"],
      "@marionette/ai-gateway/*": ["./packages/ai-gateway/src/*"],
      "@marionette/db": ["./packages/db/src"],
      "@marionette/db/*": ["./packages/db/src/*"],
      "@marionette/scenario-core": ["./packages/scenario-core/src"],
      "@marionette/scenario-core/*": ["./packages/scenario-core/src/*"],
      "@marionette/scenario-db": ["./packages/scenario-db/src"],
      "@marionette/scenario-db/*": ["./packages/scenario-db/src/*"],
      "@marionette/gate-review": ["./packages/gate-review/src"],
      "@marionette/gate-review/*": ["./packages/gate-review/src/*"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "apps/*/src/**/*.ts",
    "apps/*/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "out",
    "src",
    "server",
    "venv",
    "__pycache__",
    "output",
    ".next",
    "apps/scenario-web",
    "apps/scenario-api",
    "packages/scenario-core",
    "packages/scenario-db"
  ]
}
