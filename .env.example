NODE_ENV=development
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://root:rootpassword@localhost:5432/scenariodb?schema=public

# LLM API Keys — at least one required (falls back to mock if none set)
# Priority order: Gemini > Groq > DeepSeek > Anthropic > OpenAI > Mock
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=sk-your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GROQ_API_KEY=gsk_your_groq_api_key_here

# External APIs
# TMDB_API_KEY=your_tmdb_api_key_here
# KOFIC_API_KEY=your_kofic_api_key_here
# PINECONE_API_KEY=your_pinecone_api_key_here
