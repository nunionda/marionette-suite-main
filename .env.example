# Marionette Suite — Environment Variables (dev defaults)
# Copy to .env and adjust as needed. .env is gitignored.
# See docs/addressing-convention.md for full convention.

# ─── Web tier (browser-exposed) ────────────────────────────────
NEXT_PUBLIC_HUB_URL=http://localhost:3000
NEXT_PUBLIC_SCRIPT_WRITER_URL=http://localhost:5174
NEXT_PUBLIC_STORYBOARD_URL=http://localhost:3007
NEXT_PUBLIC_STUDIO_URL=http://localhost:3001
NEXT_PUBLIC_SCENARIO_WEB_URL=http://localhost:4000
NEXT_PUBLIC_ANALYSIS_WEB_URL=http://localhost:4007
NEXT_PUBLIC_SHORTS_FACTORY_URL=http://localhost:5178

# ─── WAS tier (internal services, server-only) ─────────────────
INTERNAL_SCRIPT_ENGINE_URL=http://localhost:3006
INTERNAL_CONTENTS_STUDIO_API_URL=http://localhost:3005
INTERNAL_ANALYSIS_API_URL=http://localhost:4006

# ─── Service ports (each backend reads its own) ────────────────
SCRIPT_ENGINE_PORT=3006
CONTENTS_STUDIO_API_PORT=3005
ANALYSIS_API_PORT=4006
STORYBOARD_PORT=3007
SHORTS_FACTORY_BACKEND_PORT=3008

# ─── CORS allowed origins (comma-separated) ────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5174,http://localhost:3001,http://localhost:4000,http://localhost:4007,http://localhost:5178,http://localhost:3007

# ─── AI Providers (Layer 1 — @marionette/ai-providers) ─────────
# All keys are optional BYOK. A missing key leaves its provider in the
# `missing-key` state and the registry's fallback chain skips to the next
# healthy candidate. See docs/pipeline-constitution.md §4 (AI prompt insertion
# points) and plans/synchronous-brewing-emerson.md §B.3 for the benchmark
# matrix that justifies each choice.

# TEXT — Top tier (BYOK; permitted within Anthropic credits per CLAUDE.md)
ANTHROPIC_API_KEY=              # Claude Opus 4.6 Thinking (Arena 1504)
# ANTHROPIC_DEFAULT_MODEL=claude-opus-4-6   # override default model id

# TEXT — Free tier defaults
GOOGLE_AI_STUDIO_KEY=           # Gemini 3.1 Pro Preview (Arena 1493, 60 rpm free)
# GEMINI_DEFAULT_MODEL=gemini-3.1-pro-preview
GROQ_API_KEY=                   # DeepSeek / Llama 4 via Groq free tier
# GROQ_DEFAULT_MODEL=deepseek-r1-distill-llama-70b   # list: GET /v1/models

# TEXT — Local (OpenAI-compatible, extensible)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_DEFAULT_MODEL=qwen3:14b
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_DEFAULT_MODEL=local-model

# IMAGE — Sprint 11b wired
# Top (BYOK): Nano Banana 2 shares GOOGLE_AI_STUDIO_KEY above
# NANO_BANANA_MODEL=gemini-3.1-flash-image-preview   # override default model id
HF_TOKEN=                       # FLUX.1 dev (free ~300 req/day) + future video models
# FLUX_HF_REPO=black-forest-labs/FLUX.1-dev           # or FLUX.1-schnell for speed

# IMAGE — Local (AUTOMATIC1111 / ComfyUI via A1111-compat shim)
A1111_BASE_URL=http://localhost:7860
A1111_DEFAULT_MODEL=sd_xl_base_1.0
COMFY_BASE_URL=http://localhost:8188
COMFY_DEFAULT_MODEL=

# VIDEO — Sprint 11c wired
# Top A (BYOK): Seedance 2.0 via fal.ai queue API (supports 9-ref + first/last + native audio)
FAL_KEY=
# SEEDANCE_MODEL=fal-ai/bytedance/seedance/v2/text-to-video   # auto-picked from request shape

# Top B (BYOK): Kling 3.0 direct (JWT) — also free tier 66 daily credits (watermarked)
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
# KLING_MODEL=kling-v3

# Free (HF Inference): HunyuanVideo (default), Wan 2.2, LTX-Video (reuses HF_TOKEN above)
# HUNYUAN_HF_REPO=tencent/HunyuanVideo
# WAN_HF_REPO=Wan-AI/Wan2.2-T2V-A14B
# LTX_HF_REPO=Lightricks/LTX-Video

# AUDIO — reserved for Sprint 11d (not yet wired)
REPLICATE_API_TOKEN=            # Alt image/video endpoint
ELEVENLABS_API_KEY=             # v3 TTS + Professional Voice Cloning

# Default provider ids — registry consults these before tier fallback
DEFAULT_TEXT_PROVIDER=gemini-3.1-pro
DEFAULT_IMAGE_PROVIDER=flux-hf
DEFAULT_VIDEO_PROVIDER=hunyuan-hf
# DEFAULT_AUDIO_PROVIDER=xtts-local    # enabled in Sprint 11d
