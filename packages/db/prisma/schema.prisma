generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id                String        @id @default(cuid())
  title             String
  genre             String        @default("")
  logline           String        @default("")
  idea              String        @default("")
  status            ProjectStatus @default(DRAFT)
  progress          Float         @default(0)
  script            String?       @db.Text
  directionPlan     Json?
  directionPlanPath String?
  protagonist       String        @default("") @db.Text
  antagonist        String        @default("") @db.Text
  characters        Json?
  worldview         String        @default("") @db.Text
  pipelineRuns      PipelineRun[]
  assets            Asset[]
  screenplay        Screenplay?
  snapshots         ProjectSnapshot[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Screenplay {
  id           String   @id @default(cuid())
  projectId    String   @unique
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentStep  Int      @default(1)
  outline      String?  @db.Text
  characters   Json?
  sceneLogs    String?  @db.Text
  draft        String?  @db.Text
  draftVersion Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PipelineRun {
  id           String          @id @default(cuid())
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase        ProductionPhase
  steps        Json
  currentStep  String?
  status       RunStatus       @default(QUEUED)
  progress     Float           @default(0)
  stepResults  Json            @default("{}")
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
}

model Asset {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        AssetType
  phase       ProductionPhase
  agentName   String
  sceneNumber Int?
  filePath    String
  fileName    String
  mimeType    String
  fileSize    Int?
  metadata    Json?
  createdAt   DateTime        @default(now())
}

model ProjectSnapshot {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String   // DIRECTION_PLAN, SCREENPLAY_OUTLINE, SCREENPLAY_DRAFT, SCREENPLAY_CHARACTERS
  version   Int
  label     String?
  data      Json
  createdAt DateTime @default(now())

  @@index([projectId, type])
  @@unique([projectId, type, version])
}

model AgentConfig {
  id        String          @id @default(cuid())
  agentName String          @unique
  phase     ProductionPhase
  provider  String
  model     String
  enabled   Boolean         @default(true)
  config    Json?
  updatedAt DateTime        @updatedAt
}

enum ProjectStatus {
  DRAFT
  PRE_PRODUCTION
  MAIN_PRODUCTION
  POST_PRODUCTION
  COMPLETED
  ARCHIVED
}

enum ProductionPhase {
  PRE
  MAIN
  POST
}

enum RunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AssetType {
  IMAGE
  VIDEO
  AUDIO
  MODEL_3D
  DOCUMENT
}
